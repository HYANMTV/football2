<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Khảo Sát & Phỏng Vấn – Giải Bóng Đá 26/3</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --green: #00C853;
  --green-dim: rgba(0,200,83,0.12);
  --blue: #2979FF;
  --blue-dim: rgba(41,121,255,0.12);
  --black: #080A0E;
  --card: #0F1318;
  --border: rgba(255,255,255,0.07);
  --text: #EEF0F5;
  --muted: #6B7A96;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:var(--black);color:var(--text);min-height:100vh;overflow-x:hidden;}

body::before{
  content:'';position:fixed;inset:0;z-index:0;pointer-events:none;
  background:radial-gradient(ellipse 60% 45% at 50% -5%,rgba(0,200,83,0.09) 0%,transparent 65%);
}
.grid-bg{position:fixed;inset:0;z-index:0;pointer-events:none;opacity:0.022;
  background-image:linear-gradient(rgba(255,255,255,1) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,1) 1px,transparent 1px);
  background-size:60px 60px;}

/* PROGRESS */
.prog-wrap{position:fixed;top:0;left:0;right:0;z-index:100;height:3px;background:rgba(255,255,255,0.05);}
.prog-bar{height:100%;transition:width 0.5s cubic-bezier(.4,0,.2,1);box-shadow:0 0 10px currentColor;}
.prog-bar.survey{background:var(--green);box-shadow:0 0 10px var(--green);}
.prog-bar.interview{background:var(--blue);box-shadow:0 0 10px var(--blue);}

.wrap{position:relative;z-index:1;max-width:660px;margin:0 auto;padding:48px 20px 80px;}

/* HERO */
.hero{text-align:center;margin-bottom:40px;animation:fadeDown .6s ease both;}
.pill-row{display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:22px;flex-wrap:wrap;}
.pill{display:inline-flex;align-items:center;gap:6px;font-size:10px;font-weight:700;letter-spacing:2px;
  text-transform:uppercase;padding:6px 14px;border-radius:100px;}
.pill.green{background:var(--green-dim);border:1px solid rgba(0,200,83,0.25);color:var(--green);}
.pill.blue{background:var(--blue-dim);border:1px solid rgba(41,121,255,0.25);color:#64B5F6;}
.hero h1{font-family:'Bebas Neue',sans-serif;font-size:clamp(42px,8vw,72px);line-height:.92;letter-spacing:2px;}
.hero h1 .g{color:var(--green);} .hero h1 .b{color:#64B5F6;}
.hero p{color:var(--muted);font-size:14px;margin-top:14px;line-height:1.7;}

/* PHASE INDICATOR */
.phase-bar{display:flex;gap:0;margin-bottom:32px;border-radius:12px;overflow:hidden;border:1px solid var(--border);}
.phase{flex:1;padding:14px 16px;text-align:center;cursor:default;transition:all .3s;}
.phase .ph-icon{font-size:20px;margin-bottom:4px;}
.phase .ph-label{font-size:11px;font-weight:600;letter-spacing:1px;text-transform:uppercase;}
.phase .ph-sub{font-size:10px;color:var(--muted);margin-top:2px;}
.phase.survey-phase{background:rgba(0,200,83,0.05);}
.phase.survey-phase.active{background:var(--green-dim);border-bottom:2px solid var(--green);}
.phase.survey-phase.active .ph-label{color:var(--green);}
.phase.survey-phase.done{background:rgba(0,200,83,0.08);}
.phase.survey-phase.done .ph-label{color:var(--green);opacity:.6;}
.phase.interview-phase{background:rgba(41,121,255,0.05);}
.phase.interview-phase.active{background:var(--blue-dim);border-bottom:2px solid var(--blue);}
.phase.interview-phase.active .ph-label{color:#64B5F6;}
.phase-divider{width:1px;background:var(--border);}

/* STEP DOTS */
.step-dots{display:flex;align-items:center;justify-content:center;gap:6px;margin-bottom:28px;}
.dot{width:8px;height:8px;border-radius:50%;background:var(--border);transition:all .3s;}
.dot.active-s{background:var(--green);box-shadow:0 0 8px var(--green);}
.dot.done-s{background:rgba(0,200,83,0.4);}
.dot.active-i{background:#64B5F6;box-shadow:0 0 8px #64B5F6;}
.dot.done-i{background:rgba(100,181,246,0.4);}
.dot-sep{width:20px;height:1px;background:var(--border);}

/* CARD */
.q-screen{display:none;animation:slideIn .35s ease both;}
.q-screen.active{display:block;}
@keyframes slideIn{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:translateX(0)}}
@keyframes fadeDown{from{opacity:0;transform:translateY(-16px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

.q-card{border-radius:20px;overflow:hidden;box-shadow:0 24px 60px rgba(0,0,0,.5);}
.q-card.survey-card{background:var(--card);border:1px solid rgba(0,200,83,0.12);}
.q-card.interview-card{background:#0C1018;border:1px solid rgba(41,121,255,0.15);}

.q-top{padding:26px 26px 0;}
.q-meta{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.q-tag{font-family:'Bebas Neue',sans-serif;font-size:11px;letter-spacing:3px;display:flex;align-items:center;gap:8px;}
.q-tag.s{color:var(--green);} .q-tag.s::before{content:'';width:14px;height:2px;background:var(--green);border-radius:1px;}
.q-tag.i{color:#64B5F6;} .q-tag.i::before{content:'';width:14px;height:2px;background:#64B5F6;border-radius:1px;}
.q-counter{font-size:12px;color:var(--muted);}
.q-counter strong{color:var(--text);}
.q-text{font-size:17px;font-weight:500;line-height:1.5;margin-bottom:24px;}

/* OPTIONS */
.opts{display:flex;flex-direction:column;gap:9px;padding:0 26px 26px;}
.opt{display:flex;align-items:center;gap:13px;padding:13px 16px;
  background:rgba(255,255,255,0.025);border:1.5px solid rgba(255,255,255,0.06);
  border-radius:11px;cursor:pointer;transition:all .18s;user-select:none;position:relative;overflow:hidden;}
.opt::before{content:'';position:absolute;inset:0;opacity:0;transition:opacity .2s;}
.survey-card .opt::before{background:linear-gradient(135deg,rgba(0,200,83,.06),transparent);}
.interview-card .opt::before{background:linear-gradient(135deg,rgba(41,121,255,.06),transparent);}
.opt:hover::before{opacity:1;}
.survey-card .opt:hover{border-color:rgba(0,200,83,.25);transform:translateX(3px);}
.interview-card .opt:hover{border-color:rgba(41,121,255,.25);transform:translateX(3px);}
.survey-card .opt.selected{border-color:var(--green);background:rgba(0,200,83,.08);}
.interview-card .opt.selected{border-color:#2979FF;background:rgba(41,121,255,.08);}
.opt.selected::before{opacity:1;}

.opt-letter{width:30px;height:30px;border-radius:7px;border:1.5px solid rgba(255,255,255,.1);
  display:flex;align-items:center;justify-content:center;
  font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:1px;color:var(--muted);
  flex-shrink:0;transition:all .18s;}
.survey-card .opt.selected .opt-letter{background:var(--green);border-color:var(--green);color:#000;box-shadow:0 3px 10px rgba(0,200,83,.3);}
.interview-card .opt.selected .opt-letter{background:#2979FF;border-color:#2979FF;color:#fff;box-shadow:0 3px 10px rgba(41,121,255,.3);}
.opt-text{font-size:14px;line-height:1.4;}
.opt.selected .opt-text{font-weight:500;}

/* TEXT INPUT */
.info-fields{padding:0 26px 26px;display:flex;flex-direction:column;gap:13px;}
.field-wrap label{display:block;font-size:10px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--muted);margin-bottom:6px;}
.field-wrap input{width:100%;background:rgba(255,255,255,.04);border:1.5px solid rgba(255,255,255,.08);
  border-radius:10px;padding:12px 15px;font-size:15px;font-family:'DM Sans',sans-serif;
  color:var(--text);outline:none;transition:all .2s;}
.field-wrap input::placeholder{color:var(--muted);}
.survey-card .field-wrap input:focus{border-color:var(--green);background:rgba(0,200,83,.04);}
.interview-card .field-wrap input:focus{border-color:#2979FF;background:rgba(41,121,255,.04);}

/* TRANSITION SCREEN */
.transition-screen{display:none;text-align:center;padding:56px 24px;animation:fadeUp .5s ease both;}
.transition-screen .icon{font-size:72px;display:block;margin-bottom:20px;}
.transition-screen h2{font-family:'Bebas Neue',sans-serif;font-size:44px;letter-spacing:2px;margin-bottom:10px;}
.transition-screen h2 span{color:#64B5F6;}
.transition-screen p{color:var(--muted);font-size:14px;line-height:1.8;margin-bottom:28px;max-width:420px;margin-left:auto;margin-right:auto;}
.btn-continue{background:#2979FF;color:#fff;border:none;padding:14px 36px;border-radius:100px;
  font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:1.5px;cursor:pointer;transition:all .22s;
  box-shadow:0 4px 18px rgba(41,121,255,.3);}
.btn-continue:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(41,121,255,.4);}

/* NAV */
.nav{display:flex;align-items:center;justify-content:space-between;
  padding:18px 26px;border-top:1px solid var(--border);background:rgba(255,255,255,.01);}
.btn-prev{background:none;border:1.5px solid var(--border);color:var(--muted);padding:10px 20px;
  border-radius:100px;font-family:'DM Sans',sans-serif;font-size:13px;cursor:pointer;transition:all .2s;}
.btn-prev:hover{border-color:rgba(255,255,255,.2);color:var(--text);}
.btn-prev:disabled{opacity:.25;pointer-events:none;}
.btn-next-s{background:var(--green);color:#000;border:none;padding:11px 26px;border-radius:100px;
  font-family:'Bebas Neue',sans-serif;font-size:15px;letter-spacing:1.5px;cursor:pointer;transition:all .22s;
  box-shadow:0 4px 14px rgba(0,200,83,.25);}
.btn-next-s:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(0,200,83,.35);}
.btn-next-s:disabled{opacity:.3;pointer-events:none;transform:none;}
.btn-next-i{background:#2979FF;color:#fff;border:none;padding:11px 26px;border-radius:100px;
  font-family:'Bebas Neue',sans-serif;font-size:15px;letter-spacing:1.5px;cursor:pointer;transition:all .22s;
  box-shadow:0 4px 14px rgba(41,121,255,.25);}
.btn-next-i:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(41,121,255,.35);}
.btn-next-i:disabled{opacity:.3;pointer-events:none;transform:none;}
.skip-btn{background:none;border:none;color:var(--muted);font-size:11px;font-family:'DM Sans',sans-serif;
  cursor:pointer;text-decoration:underline;transition:color .15s;}
.skip-btn:hover{color:var(--text);}

/* SUCCESS */
.success-screen{display:none;text-align:center;padding:64px 24px;animation:fadeUp .5s ease both;}
.success-screen .ball{font-size:80px;display:block;margin-bottom:22px;animation:bounce 1.2s ease infinite;}
@keyframes bounce{0%,100%{transform:translateY(0) rotate(0deg)}50%{transform:translateY(-13px) rotate(8deg)}}
.success-screen h2{font-family:'Bebas Neue',sans-serif;font-size:52px;letter-spacing:2px;color:var(--green);margin-bottom:10px;}
.success-screen p{color:var(--muted);font-size:15px;line-height:1.8;margin-bottom:26px;}
.btn-restart{background:transparent;border:1.5px solid var(--green);color:var(--green);
  padding:12px 30px;border-radius:100px;font-family:'DM Sans',sans-serif;
  font-size:14px;font-weight:600;cursor:pointer;transition:all .2s;}
.btn-restart:hover{background:rgba(0,200,83,.1);}
</style>
</head>
<body>

