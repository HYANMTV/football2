<script>
const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycby5GYHXfLb5QJztoWeDkn_ei3rgtv4aQhF6USbpj0E5S702kOyqSW0UL_Y2MKHHcwnxvA/exec';

// Screens order
const SURVEY_SCREENS = ['s0','s1','s2','s3','s4','s5','s6','s7','s8'];
const INTERVIEW_SCREENS = ['i0','i1','i2','i3','i4','i5'];
const ALL = [...SURVEY_SCREENS, 'transition', ...INTERVIEW_SCREENS];
const TOTAL_DOTS = SURVEY_SCREENS.length + INTERVIEW_SCREENS.length;

let current = 's0';
const answers = {};

// Build step dots
function buildDots() {
  const wrap = document.getElementById('stepDots');
  wrap.innerHTML = '';
  SURVEY_SCREENS.forEach((id,i) => {
    const d = document.createElement('div');
    d.className = 'dot'; d.id = 'dot-'+id;
    wrap.appendChild(d);
  });
  const sep = document.createElement('div'); sep.className = 'dot-sep';
  wrap.appendChild(sep);
  INTERVIEW_SCREENS.forEach((id,i) => {
    const d = document.createElement('div');
    d.className = 'dot'; d.id = 'dot-'+id;
    wrap.appendChild(d);
  });
  updateDots();
}

function updateDots() {
  const sIdx = SURVEY_SCREENS.indexOf(current);
  const iIdx = INTERVIEW_SCREENS.indexOf(current);

  SURVEY_SCREENS.forEach((id,i) => {
    const d = document.getElementById('dot-'+id);
    if (!d) return;
    d.className = 'dot' + (i < sIdx ? ' done-s' : i === sIdx ? ' active-s' : '');
  });
  INTERVIEW_SCREENS.forEach((id,i) => {
    const d = document.getElementById('dot-'+id);
    if (!d) return;
    d.className = 'dot' + (i < iIdx ? ' done-i' : i === iIdx ? ' active-i' : '');
  });

  // Progress bar
  let pct = 0;
  if (sIdx >= 0) pct = (sIdx / (TOTAL_DOTS - 1)) * 100;
  if (iIdx >= 0) pct = ((SURVEY_SCREENS.length + iIdx) / (TOTAL_DOTS - 1)) * 100;
  const bar = document.getElementById('progBar');
  bar.style.width = pct + '%';
  bar.className = 'prog-bar ' + (iIdx >= 0 ? 'interview' : 'survey');

  // Phase bar
  const inInterview = iIdx >= 0;
  document.getElementById('phase-survey').className = 'phase survey-phase' + (inInterview ? ' done' : ' active');
  document.getElementById('phase-interview').className = 'phase interview-phase' + (inInterview ? ' active' : '');
}

function showScreen(id) {
  document.querySelectorAll('.q-screen, .transition-screen, .success-screen').forEach(el => {
    el.classList.remove('active');
    el.style.display = '';
  });
  if (id === 'transition') {
    document.getElementById('transitionScreen').style.display = 'block';
  } else if (id === 'success') {
    document.getElementById('successScreen').style.display = 'block';
    document.getElementById('progBar').style.width = '100%';
    document.getElementById('stepDots').style.display = 'none';
    document.getElementById('phaseBar').style.display = 'none';
    document.querySelector('.hero').style.display = 'none';
  } else {
    const el = document.getElementById('screen-' + id);
    el.classList.add('active');
  }
  window.scrollTo({top:0,behavior:'smooth'});
}

function pick(el, key) {
  document.querySelectorAll('#opts-'+key+' .opt').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  answers[key] = el.querySelector('.opt-text').textContent.trim();
  const btn = document.getElementById('nx-'+key);
  if (btn) btn.disabled = false;
}

function goNext(id) {
  if (id === 's0') {
    const name = document.getElementById('s-name').value.trim();
    if (!name) {
      document.getElementById('s-name').style.borderColor='#FF5252';
      setTimeout(()=>document.getElementById('s-name').style.borderColor='',2000);
      return;
    }
    answers.name = name;
    answers.mssv = document.getElementById('s-mssv').value.trim();
  }
  navigateFrom(id, 1);
}
function goPrev(id) { navigateFrom(id, -1); }
function skip(id) { navigateFrom(id, 1); }

function navigateFrom(id, dir) {
  const isSurvey = id.startsWith('s');
  const list = isSurvey ? SURVEY_SCREENS : INTERVIEW_SCREENS;
  const idx = list.indexOf(id);
  const nextIdx = idx + dir;

  if (isSurvey) {
    if (nextIdx >= list.length) { current = 'transition'; showScreen('transition'); updateDots(); return; }
    if (nextIdx < 0) return;
    current = list[nextIdx];
  } else {
    if (nextIdx >= list.length) { submitAll(); return; }
    if (nextIdx < 0) { current = 'transition'; showScreen('transition'); updateDots(); return; }
    current = list[nextIdx];
  }
  showScreen(current);
  updateDots();
}

function startInterview() {
  current = 'i0';
  showScreen('i0');
  updateDots();
}

async function submitAll() {
  showScreen('success');
  const payload = {
    loai: 'Tổng hợp',
    q1: answers.name||'',
    q2: answers.s1||'',
    q3: answers.s2||'',
    q4: answers.s3||'',
    q5: answers.s4||'',
    q6: answers.s5||'',
    q7: answers.s6||'',
    q8: answers.s7||'',
    q9: answers.s8||'',
    pv1: answers.i0||'',
    pv2: answers.i1||'',
    pv3: answers.i2||'',
    pv4: answers.i3||'',
    pv5: answers.i4||'',
    pv6: answers.i5||'',
    mssv: answers.mssv||'',
  };
  try {
    await fetch(SCRIPT_URL,{method:'POST',mode:'no-cors',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
  } catch(e){}
}

function restart() {
  Object.keys(answers).forEach(k => delete answers[k]);
  document.querySelectorAll('.opt').forEach(o => o.classList.remove('selected'));
  document.querySelectorAll('[id^="nx-"]').forEach(b => b.disabled = true);
  document.getElementById('s-name').value='';
  document.getElementById('s-mssv').value='';
  document.getElementById('successScreen').style.display='none';
  document.getElementById('stepDots').style.display='';
  document.getElementById('phaseBar').style.display='';
  document.querySelector('.hero').style.display='';
  current = 's0';
  showScreen('s0');
  buildDots();
}

buildDots();
showScreen('s0');
</script>
